// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Tracks each unique domain that has been checked
model Domain {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "google.com"
  checks    Check[]
  votes     Vote[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// Records each uptime check performed
model Check {
  id           String   @id @default(cuid())
  domain       Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  domainId     String
  isUp         Boolean
  statusCode   Int?
  responseTime Int? // milliseconds
  reason       String? // failure reason if down
  checkedAt    DateTime @default(now())

  @@index([domainId, checkedAt(sort: Desc)])
  @@index([checkedAt(sort: Desc)])
}

// Records community votes (up/down) per domain
model Vote {
  id        String   @id @default(cuid())
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  domainId  String
  type      VoteType
  ipHash    String // hashed IP for anti-abuse (not raw IP)
  createdAt DateTime @default(now())

  @@index([domainId])
  @@index([ipHash, domainId])
}

enum VoteType {
  UP
  DOWN
}
